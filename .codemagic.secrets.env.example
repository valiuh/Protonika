# Copy this file to .codemagic.secrets.env for local reference only.
# Never commit .codemagic.secrets.env with real values.

# Required by tests workflow to trigger deploy workflow via Codemagic REST API
CM_API_TOKEN=<codemagic_api_token>
CM_APP_ID=<codemagic_app_id>

# Required by deploy workflow (Firebase App Distribution + Storage upload)
FIREBASE_SERVICE_ACCOUNT=<firebase_service_account_json>
FIREBASE_ANDROID_APP_ID=<firebase_android_app_id>
FIREBASE_ANDROID_TESTER_GROUP=<firebase_tester_group_alias>
FIREBASE_PROJECT_ID=<firebase_project_id>
FIREBASE_STORAGE_BUCKET=<firebase_storage_bucket_name>
